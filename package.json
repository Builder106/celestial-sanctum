{
  "name": "celestial-sanctum",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "gen:firebase-env": "node scripts/gen-firebase-env.mjs",
    "postinstall": "node scripts/gen-firebase-env.mjs",
    "start": "npm run gen:firebase-env && ng serve",
    "build": "npm run gen:firebase-env && ng build",
    "watch": "npm run gen:firebase-env && ng build --watch --configuration development",
    "test": "npm run gen:firebase-env && ng test",
    "test:e2e": "bddgen --config=playwright.config.ts && playwright test --config=playwright.config.ts",
    "test:demo": "DEMO=1 bddgen --config=playwright.demo.config.ts && DEMO=1 playwright test --config=playwright.demo.config.ts",
    "serve:ssr:celestial-sanctum": "node dist/celestial-sanctum/server/server.mjs"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@angular/animations": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-server": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/ssr": "^22.0.0",
    "@capacitor-firebase/authentication": "^8.2.0",
    "@capacitor-firebase/firestore": "^8.2.0",
    "@capacitor-firebase/messaging": "^8.2.0",
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/inter": "^5.2.8",
    "@portabletext/types": "^4.0.2",
    "@sanity/client": "^7.22.1",
    "@sanity/image-url": "^2.1.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "express": "^5.1.0",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.10.0",
    "ical.js": "^2.2.1",
    "minisearch": "^7.2.0",
    "motion": "^12.40.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.4",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/express": "^5.0.1",
    "@types/node": "^25.9.1",
    "@vercel/node": "^5.8.17",
    "jsdom": "^29.1.1",
    "playwright-bdd": "^9.0.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.0",
    "vitest": "^4.1.8"
  }
}
