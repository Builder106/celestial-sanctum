# Vercel
.vercel

# Capacitor — native build outputs + machine-specific config. The
# native project trees (ios/, android/) themselves ARE committed so
# Xcode / Android Studio settings, plugin configs, and Info.plist
# changes are versioned alongside the web code. These paths are the
# transient build artifacts inside those trees.
ios/App/App/public
ios/App/Pods
ios/App/build
ios/App/DerivedData
ios/.build
android/.gradle
android/app/build
android/build
android/local.properties
android/app/release
android/app/debug

# @capacitor/assets intermediate rasters. The committed sources are
# resources/icon.png + resources/splash.png; anything else under
# resources/ is a working file from the seal-rasterization pipeline.
/resources/icon-fg.png
/resources/seal-splash.png

# PWA artifacts generated by @capacitor/assets as a side-effect.
# Capacitor (native iOS / Android) is the mobile target — PWA is not
# on the roadmap yet. Ignore until that decision lands so we don't
# ship a half-wired manifest under /manifest.webmanifest.
/icons/
/public/manifest.webmanifest

# Firebase config files — NOT committed. This repo is public, and these
# carry the Firebase API key + project IDs. They ship inside the app
# bundle (guarded by Security Rules / App Check / API-key restrictions),
# but we keep them out of git on a public repo. Each machine / the
# release pipeline supplies its own copy:
#   ios/App/App/GoogleService-Info.plist  (Firebase Console -> iOS app)
#   android/app/google-services.json       (Firebase Console -> Android app)
# The Xcode project references the plist by path, so a fresh clone must
# add the file before an iOS build.
**/GoogleService-Info.plist
**/google-services.json

# Generated at build time by scripts/gen-firebase-env.mjs from the
# NG_APP_FIREBASE_* env vars (so the keys live in env/Vercel, not git).
src/app/core/firebase/firebase.env.generated.ts
public/firebase-messaging-sw.js

# Firebase Admin SDK service-account keys — SECRET (full backend access).
# NEVER commit. The deployed API reads the key from the FIREBASE_SERVICE_ACCOUNT
# Vercel env var, not from a file in the repo.
*firebase-adminsdk*.json
*service-account*.json
/secrets/